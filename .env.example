# Database (Docker Compose автоматаар тохируулна)
# Локал хөгжүүлэлтэнд SQLite ашиглана:
# DATABASE_URL=sqlite:///./news.db
# Docker дээр PostgreSQL:
POSTGRES_PASSWORD=geregnews_secret

# Required
ANTHROPIC_API_KEY=your-api-key-here
SECRET_KEY=your-secret-key-here

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here

# Optional AI fallbacks
GEMINI_API_KEY=
GROQ_API_KEY=

# Push notifications (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@geregnews.mn

# Production domain (optional)
SITE_URL=
